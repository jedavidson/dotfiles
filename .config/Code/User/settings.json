{
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "editor.insertSpaces": false,
  "editor.suggest.preview": false,
  "editor.suggestSelection": "first",
  "workbench.editorAssociations": {
    "git-rebase-todo": "default"
  },
  "files.trimTrailingWhitespace": false,
  "security.workspace.trust.untrustedFiles": "open",
  "window.commandCenter": false,
  "window.customTitleBarVisibility": "never",
  "window.titleBarStyle": "native",
  "workbench.startupEditor": "newUntitledFile",

  "workbench.colorTheme": "Moonlight",
  "workbench.iconTheme": "symbols",
  "workbench.productIconTheme": "fluent-icons",
  "gruvboxMaterial.colorfulSyntax": true,
  "gruvboxMaterial.italicComments": false,
  "gruvboxMaterial.darkContrast": "hard",
  "gruvboxMaterial.darkPalette": "original",
  "gruvboxMaterial.darkWorkbench": "high-contrast",
  "gruvboxMaterial.lightContrast": "hard",
  "gruvboxMaterial.lightPalette": "original",
  "gruvboxMaterial.lightWorkbench": "high-contrast",

  "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.fontSize": 14,
  "chat.fontSize": 15,

  "terminal.integrated.allowChords": false,
  "terminal.integrated.commandsToSkipShell": ["-workbench.action.quickOpen"],
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
  "terminal.integrated.fontSize": 14,

  "[cpp]": {
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false
  },
  "C_Cpp.intelliSenseEngine": "disabled",
  "clangd.path": "/usr/bin/clangd-18",
  "clangd.arguments": [
    // Thread cap is per-machine via the CLANGD_JOBS env var (e.g. set in
    // /etc/environment). MUST be defined on every machine: an empty -j=
    // is rejected by clangd and stops the language server from starting.
    "-j=${env:CLANGD_JOBS}"
  ],
  "clangd.onConfigChanged": "restart",
  "cmake.configureOnOpen": false,
  "cmake.configureOnEdit": false,

  "python.analysis.typeCheckingMode": "basic",
  "python.REPL.enableREPLSmartSend": false,
  "notebook.output.scrolling": true,
  "ruff.lineLength": 120,

  "todo-tree.general.statusBar": "current file",
  "todo-tree.highlights.useColourScheme": true,
  "todo-tree.general.tags": [
    "TODO",
    "FIXME",
    "BUG",
    "NOTE",
    "HACK",
    "XXX"
  ],
  "todo-tree.highlights.backgroundColourScheme": [
    "violet",
    "orange",
    "red",
    "green",
    "blue",
    "yellow"
  ],
  "todo-tree.highlights.foregroundColourScheme": [
    "white",
    "black",
    "white",
    "white",
    "white",
    "black"
  ],
  "todo-tree.ripgrep.ripgrep": "/usr/share/code/resources/app/node_modules/@vscode/ripgrep-universal/bin/linux-x64/rg",

  "chat.agent.enabled": false,
  "chat.disableAIFeatures": true,
}

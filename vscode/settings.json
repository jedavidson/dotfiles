{
  "workbench.startupEditor": "newUntitledFile",
  "workbench.editor.untitled.hint": "hidden",
  "files.trimTrailingWhitespace": true,
  "security.workspace.trust.untrustedFiles": "open",
  "editor.suggestSelection": "first",
  "editor.suggest.preview": false,
  "window.commandCenter": false,
  "update.showReleaseNotes": false,

  // Tutoring
  // "window.zoomLevel": 1,
  // "editor.fontSize": 16,
  // "terminal.integrated.fontSize": 16,

  // Font settings
  "editor.fontFamily": "MesloLGS Nerd Font Mono",
  "terminal.integrated.fontFamily": "MesloLGS Nerd Font Mono",

  // Terminal settings
  "terminal.integrated.allowChords": false,
  "material-icon-theme.activeIconPack": "react",
  "material-icon-theme.folders.color": "#adadad",
  "gruvboxMaterial.darkContrast": "hard",
  "gruvboxMaterial.darkPalette": "original",
  "gruvboxMaterial.darkWorkbench": "high-contrast",
  "gruvboxMaterial.italicComments": false,
  "gruvboxMaterial.colorfulSyntax": true,

  // File exclusion settings
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
    "__pycache__": true,
    ".pytest_cache": true,
    ".DS_Store": true
  },

  // C/C++ settings
  "C_Cpp.autocomplete": "disabled",
  "C_Cpp.intelliSenseEngine": "disabled",
  "[c]": {
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.wordBasedSuggestions": false,
    "editor.suggest.insertMode": "replace",
    "editor.semanticHighlighting.enabled": true,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true
  },
  "[cpp]": {
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.wordBasedSuggestions": false,
    "editor.suggest.insertMode": "replace",
    "editor.semanticHighlighting.enabled": true,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true
  },

  // Rust settings
  "[rust]": {
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true
  },

  // LaTeX settings
  "[latex]": {
    "editor.wordWrap": "on",
    "editor.formatOnPaste": false
  },

  // Haskell settings
  "[haskell]": {
    "editor.tabSize": 2
  },
  "haskell.manageHLS": "GHCup",
  "haskell.serverEnvironment": {
    "PATH": "${HOME}/.ghcup/bin:$PATH"
  },
  "haskell.plugin.hlint.diagnosticsOn": false,
  "haskell.plugin.hlint.codeActionsOn": false,
}

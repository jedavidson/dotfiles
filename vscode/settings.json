{
  // General settings
  "workbench.startupEditor": "newUntitledFile",
  "workbench.editor.untitled.hint": "hidden",
  "files.trimTrailingWhitespace": true,
  "security.workspace.trust.untrustedFiles": "open",
  "editor.suggest.preview": false,
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.bracketPairColorization.enabled": false,
  "editor.renderWhitespace": "boundary",

  // Theme plugin settings
  "workbench.colorTheme": "Monokai Dimmed",
  "workbench.iconTheme": "material-icon-theme",
  "oneDarkPro.italic": false,
  "oneDarkPro.bold": true,
  "oneDarkPro.vivid": true,
  "oneDarkPro.editorTheme": "Solarized",
  "gruvboxMaterial.darkPalette": "mix",
  "gruvboxMaterial.italicComments": false,
  "gruvboxMaterial.darkContrast": "hard",
  "gruvboxMaterial.darkWorkbench": "flat",
  "material-icon-theme.activeIconPack": "react",
  "material-icon-theme.folders.color": "#adadad",

  // Font settings
  "editor.fontFamily": "DejaVuSansMono Nerd Font Mono",
  "editor.fontSize": 13,
  "terminal.integrated.fontFamily": "DejaVuSansMono Nerd Font Mono",
  "terminal.integrated.fontSize": 13,

  // File exclusion settings
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },

  // IntelliSense settings
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",

  // Remote - SSH settings
  "remote.SSH.lockfilesInTmp": true,
  "remote.SSH.remoteServerListenOnSocket": true,
  "remote.SSH.remotePlatform": {
    "vscode.cse.unsw.edu.au": "linux"
  },

  // Python settings
  "python.analysis.typeCheckingMode": "basic",
  "python.languageServer": "Pylance",
  "python.testing.pytestArgs": ["."],
  "python.testing.pytestEnabled": true,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },

  // C/C++ settings
  "C_Cpp.intelliSenseEngine": "Disabled",
  "clangd.onConfigChanged": "restart",

  // Haskell settings
  "[haskell]": {
    "editor.tabSize": 2,
    "editor.suggest.preview": false
  },

  // LaTeX settings
  "[latex]": {
    "editor.wordWrap": "on",
    "editor.formatOnPaste": false,
    "editor.suggestSelection": "recentlyUsedByPrefix"
  },
  "latex-workshop.view.pdf.viewer": "tab",

  // JavaScript settings
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[javascriptreact]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescriptreact]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },

  // SQL settings
  "[sql]": {
    "editor.tabSize": 2
  },

  // GitHub Copilot settings
  "github.copilot.enable": {
    "*": false,
    "yaml": false,
    "plaintext": false,
    "markdown": false
  }
}
